# --- CORE AI BRAIN (OpenAI) ---
# Required for GPT-4o (Vision), GPT-4-Turbo (Audit), and Whisper (Voice)
OPENAI_API_KEY=your_openai_key_here

# --- FINANCIAL BANKING AGENT (Plaid) ---
# Get these from the Plaid Dashboard (Development/Sandbox mode)
PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_secret
PLAID_ENV=sandbox

# --- AUTONOMOUS OUTREACH (Email) ---
# Use a Gmail App Password for secure SMTP
SENTINEL_EMAIL=your_professional_email@gmail.com
SENTINEL_EMAIL_PASSWORD=your_16_digit_app_password

# --- SYSTEM CONFIGURATION ---
LOG_LEVEL=INFO
DATABASE_PATH=./data/memory_db
PORT=8501
